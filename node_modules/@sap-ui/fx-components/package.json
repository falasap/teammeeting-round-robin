  "scripts": {
    "build": "node scripts/sync-theme-tokens.mjs && node node_modules/.bin/tsup && npm run build:dts && npm run build:css && npm run build:component-css && npm run build:theme && npm run build:tokens",
    "build:dts": "tsc -p tsconfig.build.json && node -e \"const fs=require('fs'),p=require('path'),dir=p.resolve('dist/components');if(fs.readdirSync(dir).includes('Tabbar')){const s=p.join(dir,'Tabbar'),d=p.join(dir,'tabbar');fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)));fs.rmSync(s,{recursive:true})}\"",
    "build:css": "tailwindcss -i src/theme/styles-input.css -o dist/styles.css --minify",
    "build:component-css": "node scripts/build-component-css.mjs",
    "build:theme": "cp src/theme/sapphire-theme.css dist/theme.css && sed '/@source/d;/Scan library source/d' src/theme/sapphire-theme.css > dist/theme-tokens.css",
    "build:tokens": "cp src/theme/tokens.css dist/tokens.css",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.{ts,tsx}",
    "prelint:ci": "rimraf reports/*.json",
    "lint:ci": "eslint src/**/*.{ts,tsx} -f json -o reports/eslint.json || true",
    "type-check": "tsc --noEmit",
    "dev:demo": "npm --prefix demos/demo run dev",
    "dev:el-demo": "npm --prefix demos/el-demo run dev",
    "build:demo": "npm --prefix demos/demo run build",
    "build:el-demo": "npm --prefix demos/el-demo run build",
    "build:all": "npm run build && npm run build:demo && npm run build:el-demo",
    "generate:api-registry": "node scripts/generate-api-registry.mjs",
    "combine:reports": "mkdir -p junit && jrm junit/TEST-results.xml \"test-reports/*.xml\"",
    "pretest:ci": "rimraf test-reports coverage junit",
    "test:ci": "vitest run --coverage",
    "posttest:ci": "npm run combine:reports",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
